{
  "version": 2,
  "builds": [
    {
      "src": "manga-indo/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "manga-indo/dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
